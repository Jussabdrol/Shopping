# Provided automatically by Railway when you attach a Postgres service.
# Locally, point this at any Postgres instance you want to use.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Shared password that gates access to the app.
APP_PASSWORD=change-me

# HMAC secret used to sign session cookies. Use at least 32 random chars.
# Generate with: openssl rand -hex 32
SESSION_SECRET=change-me-too
